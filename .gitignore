# 1. ЗАВИСИМОСТИ (Тяжелые папки, которые скачиваются локально)
node_modules/
.pnp
.pnp.js

# 2. СЕКРЕТЫ И ПАРОЛИ (КРИТИЧЕСКИ ВАЖНО - защита от утечек)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# 3. СБОРКА И ТЕСТЫ (Сгенерированный код React/Next.js/Fullstack)
build/
dist/
.next/
out/
coverage/

# 4. ЛОГИ (Системный мусор ошибок)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# 5. СИСТЕМНЫЕ ФАЙЛЫ ОС (Скрытые файлы Windows и macOS)
.DS_Store
Thumbs.db

# 6. НАСТРОЙКИ РЕДАКТОРОВ (Чтобы не перезаписывать настройки коллег)
.idea/
.vscode/

venv/
.agent/
__pycache__/
